#!/bin/sh
# Chat Grok interactif minimal, sans TUI. Contexte conservé entre tours (-c).
# Pour l'expérience complète (menus, streaming, reprise de session) : grok-tui.
echo "Grok chat — 'exit' or Ctrl+C to quit."
FIRST=1
while printf "\n> " && IFS= read -r line; do
  [ "$line" = "exit" ] && break
  [ -z "$line" ] && continue
  if [ "$FIRST" = 1 ]; then
    grok --always-approve -p "$line"; FIRST=0
  else
    grok --always-approve -c -p "$line"
  fi
done
