#!/usr/bin/env python3
# grok-tui — TUI clone of the official grok CLI for armv7l (the native TUI
# crashes under 64-on-32 emulation; this one drives the reliable headless
# streaming mode).
# v3: real event-driven, keyboard-controlled TUI —
#   arrows = navigate menus (welcome, resume) / input history
#   PgUp/PgDn = scroll the transcript, Esc = interrupt the turn
#   editable input (left/right, backspace), visible cursor
# Design and palette lifted from grok 0.2.102 on darwin.
# Per-turn options are passed through: grok-tui --max-turns 10 ; --safe starts
# in "normal" mode (see permission modes below).
import json
import os
import queue
import re
import select
import shutil
import subprocess
import sys
import termios
import threading
import time
import unicodedata

BORDER = "\033[38;2;51;51;51m"
IBORDER = "\033[38;2;80;80;88m"
LOGO = "\033[38;2;112;112;112m"
WHITE = "\033[1m\033[38;2;225;225;225m"
GOLD = "\033[1m\033[38;2;224;175;104m"
DIM = "\033[38;2;108;108;108m"
KEY = "\033[38;2;120;120;120m"
TEXT = "\033[38;2;200;200;200m"
MODEL = "\033[38;2;128;128;128m"
LIGHT = "\033[38;2;223;223;223m"
USERBG = "\033[48;2;36;36;36m"
SELBG = "\033[48;2;50;50;58m"
RED = "\033[38;2;220;100;100m"
R = "\033[0m"

LOGO_ART = [
    "⠀⠀⠀⠀⠀⠀⣀⣀⡀⠀⠀⠀⢀⠄",
    "⠀⠀⠀⣠⣾⠿⠛⠛⠛⠛⢠⣴⠁⠀",
    "⠀⠀⣼⡿⠁⠀⠀⠀⢠⣴⠻⣿⡀⠀",
    "⠀⠀⣿⡇⠀⠀⠀⠔⠁⠀⠀⣿⡇⠀",
    "⠀⠀⢹⣷⠀⠀⠀⠀⠀⢠⣴⢿⠀⠀",
    "⠀⢠⠞⠁⢠⣶⣶⣶⣶⠿⠋⠀⠀⠀",
    "⠐⠁⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀",
]

GROK_BIN = (os.environ.get("GROK_BIN")
            or ("grok-bin" if shutil.which("grok-bin") else "grok"))
EXTRA = sys.argv[1:]
SAFE = "--safe" in EXTRA
EXTRA = [a for a in EXTRA if a != "--safe"]
# Permission modes (Shift+Tab cycle, like the official TUI).
# Headless has no approval channel: in "normal" mode a turn that wants to use
# a tool ends "cancelled"; "plan" = thinks without executing;
# "always-approve" (default) = tools auto-approved.
PMODES = ["normal", "plan", "always-approve"]
PMODE_FLAGS = {
    "normal": [],
    "plan": ["--permission-mode", "plan"],
    "always-approve": ["--always-approve"],
}
INITIAL_PMODE = "normal" if SAFE else "always-approve"
# Slash commands (headless-compatible subset of the official TUI's 56).
SLASH_COMMANDS = [
    ("/help", "Browse commands and keyboard shortcuts"),
    ("/new", "Start a new session"),
    ("/clear", "Start a new session"),
    ("/compact", "Compact conversation history"),
    ("/resume", "Resume a previous session"),
    ("/sessions", "Resume a previous session"),
    ("/fork", "Branch the current session (next turn forks)"),
    ("/export", "Export this session transcript as Markdown"),
    ("/model", "Switch the active model"),
    ("/mcps", "Show MCP server status"),
    ("/remember", "Save a memory note (usage: /remember <note>)"),
    ("/recap", "Summarize the session so far"),
    ("/session-info", "Show session info"),
    ("/multiline", "Toggle multiline input (swap Enter and Ctrl+J)"),
    ("/home", "Return to the welcome screen"),
    ("/docs", "Show links to the docs"),
    ("/version", "Show grok version"),
    ("/quit", "Quit the application"),
    ("/exit", "Quit the application"),
]
MODEL_LABEL = "Grok 4.5 (high)"
CONTEXT_WINDOW = "500K"
ANSI_RE = re.compile(r"\033\[[0-9;]*[A-Za-z]")


def vlen(s):
    return len(ANSI_RE.sub("", s))


def dwidth(s):
    """Display width: wide/fullwidth chars (CJK...) count as 2 columns."""
    w = 0
    for ch in ANSI_RE.sub("", s):
        w += 2 if unicodedata.east_asian_width(ch) in ("W", "F") else 1
    return w


def fmt_tokens(n):
    if n >= 1_000_000:
        return "%.1fM" % (n / 1_000_000)
    if n >= 1000:
        return "%dK" % (n // 1000)
    return str(n)


def extract_tokens(usage):
    total = 0

    def walk(v):
        nonlocal total
        if isinstance(v, dict):
            for x in v.values():
                walk(x)
        elif isinstance(v, (int, float)):
            total += int(v)

    walk(usage or {})
    return total


def wrap_plain(text, width, indent):
    """Wrap plain text into lines <= width, with indentation."""
    out = []
    for seg in text.split("\n"):
        line = indent
        for word in seg.split(" "):
            while len(word) > width - len(indent):
                room = width - len(line)
                head, word = word[:room], word[room:]
                out.append(line + head)
                line = indent
            if line != indent and len(line) + 1 + len(word) > width:
                out.append(line)
                line = indent + word
            elif line == indent:
                line = indent + word
            else:
                line = line + " " + word
        out.append(line)
    return out or [indent]


class App:
    def __init__(self):
        self._read_size()
        self.lines = []                # frozen transcript (ANSI strings)
        self.cur_style = None          # paragraph currently streaming
        self.cur_plain = ""
        self.cur_indent = "   "
        self.scroll = 0                # lines scrolled up from bottom
        self.input_buf = ""
        self.input_pos = 0
        self.hist = []
        self.hist_i = 0
        self.mode = "menu"             # menu | input | resume | busy
        self.menu_i = 0
        self.resume_rows = []
        self.resume_i = 0
        self.used = 0
        self.session_id = None
        self.proc = None
        self.events = queue.Queue()
        self.status = ""
        self.turn_stop = "?"
        self.pmode = INITIAL_PMODE
        self.model = None
        self.model_label = MODEL_LABEL
        self.slash_i = 0
        self.carry = None
        self.pending_compact = False
        self.fork_next = False
        self.multiline = False
        self.turn_text = ""
        self.model_rows = []
        self.model_i = 0
        self.spin_i = 0
        self.recv_chars = 0
        self.phase = "Working"
        self.phase_t0 = 0.0
        self._last_draw = 0.0
        self._last_size_check = 0.0

    def _read_size(self):
        size = shutil.get_terminal_size()
        rows = int(os.environ.get("GROK_TUI_ROWS", size.lines))
        cols = int(os.environ.get("GROK_TUI_COLS", size.columns))
        # Marge virtuelle en bas : certains ecrans (console du pad) affichent
        # moins de lignes que le terminal n'en declare -> on remonte toute
        # l'interface de GROK_TUI_MARGIN lignes (defaut 2).
        margin = int(os.environ.get("GROK_TUI_MARGIN", "2"))
        self.H = max(rows - margin, 14)
        self.W = max(60, min(cols, 120))
        self.RH = self.H - 5           # transcript height (rows 2..H-4)

    def check_resize(self):
        """Detecte un redimensionnement du terminal et re-cadre tout."""
        now = time.time()
        if now - self._last_size_check < 1.0:
            return
        self._last_size_check = now
        old = (self.H, self.W)
        self._read_size()
        if (self.H, self.W) != old:
            sys.stdout.write("\033[2;%dr\033[2J" % (self.H - 4))
            self.draw(force=True)

    # ---- transcript -------------------------------------------------------
    def add(self, ansi_line=""):
        self.lines.append(ansi_line)

    def add_par(self, style, text, indent="   "):
        for pl in wrap_plain(text, self.W - 2, indent):
            self.add(style + pl + R)

    def stream_start(self, style, first_prefix):
        self.flush_stream()
        self.cur_style = style
        self.cur_plain = first_prefix

    def stream_add(self, chunk):
        self.cur_plain += chunk

    def flush_stream(self):
        if self.cur_style is not None and self.cur_plain:
            self.add_par(self.cur_style, self.cur_plain, self.cur_indent)
        self.cur_style = None
        self.cur_plain = ""

    def cur_lines(self):
        if self.cur_style is None or not self.cur_plain:
            return []
        return [self.cur_style + pl + R
                for pl in wrap_plain(self.cur_plain, self.W - 2,
                                     self.cur_indent)]

    def user_band(self, prompt):
        ts = time.strftime("%-I:%M %p")
        line = " ❯ " + prompt.replace("\n", " ⏎ ")
        fill = max(1, self.W - dwidth(line) - len(ts) - 2)
        self.add()
        self.add(USERBG + TEXT + line + " " * fill + DIM + ts + "  " + R)

    def welcome(self):
        w = min(self.W - 4, 104)
        self.add()
        self.add("  " + BORDER + "╭" + "─" * (w - 2) + "╮" + R)
        rows = [
            WHITE + "Grok Build Beta  " + R + DIM + "0.2.102 · armv7 (qemu)" + R,
            "",
            GOLD + "Grok 4.5 is here!" + R,
            DIM + "Grok 4.5 is now available on your SmartPad." + R,
            "",
            "",
            "",
        ]
        for i in range(7):
            txt = rows[i]
            fill = w - 2 - (2 + 14 + 3 + vlen(txt)) - 2
            self.add("  " + BORDER + "│" + R + "  " + LOGO + LOGO_ART[i] + R
                     + "   " + txt + " " * max(0, fill) + "  "
                     + BORDER + "│" + R)
        self.add("  " + BORDER + "╰" + "─" * (w - 2) + "╯" + R)
        self.add()
        self.add("  " + DIM + "\033[1mTip: \033[0m" + DIM
                 + "↑/↓ menus & history · PgUp/PgDn scroll · Esc interrupt"
                 + R)
        if EXTRA:
            self.add("  " + DIM + "per-turn options: " + " ".join(EXTRA) + R)

    def slash_suggestions(self):
        word = self.input_buf.split(" ")[0]
        out = [c for c in SLASH_COMMANDS if c[0].startswith(word)]
        self.slash_i = min(self.slash_i, max(0, len(out) - 1))
        return out

    # ---- rendering --------------------------------------------------------
    def at(self, r, c=1):
        return "\033[%d;%dH" % (r, c)

    def menu_panel(self):
        items = [("New session", "enter"), ("Resume session", "ctrl+s"),
                 ("Quit", "ctrl+q")]
        w = min(self.W - 4, 104)
        out = ["  " + BORDER + "╭" + "─" * (w - 2) + "╮" + R]
        for i, (label, k) in enumerate(items):
            sel = i == self.menu_i
            bg = SELBG if sel else ""
            body = ("› " if sel else "  ") + label
            fill = w - 5 - len(body) - len(k)
            out.append("  " + BORDER + "│" + R + bg + " " + WHITE + body + R
                       + bg + " " * max(0, fill) + KEY + k + R + bg + "  " + R
                       + BORDER + "│" + R)
        out.append("  " + BORDER + "╰" + "─" * (w - 2) + "╯" + R)
        return out

    def load_models(self):
        try:
            out = subprocess.run([GROK_BIN, "models"], capture_output=True,
                                 text=True, timeout=180).stdout
        except Exception:
            out = ""
        rows, in_list = [], False
        for line in out.splitlines():
            if "Available models" in line:
                in_list = True
                continue
            if in_list and line.strip():
                name = line.strip().lstrip("*").strip().split(" ")[0]
                if name:
                    rows.append((name, "(default)" in line))
        self.model_rows = rows
        self.model_i = 0

    def model_panel(self):
        w = min(self.W - 4, 104)
        out = ["  " + BORDER + "╭" + "─" * (w - 2) + "╮" + R]
        title = (WHITE + "Switch model" + R + DIM
                 + "   ↑/↓ + enter · esc cancel" + R)
        out.append("  " + BORDER + "│" + R + "  " + title
                   + " " * max(0, w - 4 - vlen(title) - 2) + "  "
                   + BORDER + "│" + R)
        for i, (name, is_def) in enumerate(self.model_rows):
            sel = i == self.model_i
            bg = SELBG if sel else ""
            left = ("› " if sel else "  ") + name + (" (default)" if is_def else "")
            fill = w - 4 - len(left)
            style = LIGHT if sel else TEXT
            out.append("  " + BORDER + "│" + R + bg + " " + style + left + R
                       + bg + " " * max(1, fill) + " " + R + BORDER + "│" + R)
        out.append("  " + BORDER + "╰" + "─" * (w - 2) + "╯" + R)
        return out

    def resume_panel(self):
        w = min(self.W - 4, 104)
        out = ["  " + BORDER + "╭" + "─" * (w - 2) + "╮" + R]
        title = (WHITE + "Resume session" + R + DIM
                 + "   ↑/↓ + enter · esc cancel" + R)
        out.append("  " + BORDER + "│" + R + "  " + title
                   + " " * max(0, w - 4 - vlen(title) - 2) + "  "
                   + BORDER + "│" + R)
        for i, (sid, date, summary) in enumerate(self.resume_rows):
            sel = i == self.resume_i
            bg = SELBG if sel else ""
            left = ("› " if sel else "  ") + summary[: w - 24]
            fill = w - 4 - len(left) - len(date)
            style = LIGHT if sel else TEXT
            out.append("  " + BORDER + "│" + R + bg + " " + style + left + R
                       + bg + " " * max(1, fill) + DIM + date + R + bg
                       + " " + R + BORDER + "│" + R)
        out.append("  " + BORDER + "╰" + "─" * (w - 2) + "╯" + R)
        return out

    def shortcuts_panel(self):
        rows = [
            ("Send", "Enter"),
            ("Insert newline", "Ctrl+J / Alt+Enter"),
            ("Cancel turn", "Esc / Ctrl+c"),
            ("Cycle mode (normal/plan/always-approve)", "Shift+Tab"),
            ("New session", "/new"),
            ("Resume session", "Ctrl+s / /resume"),
            ("Scroll transcript", "PgUp / PgDn"),
            ("Input history", "\u2191 / \u2193"),
            ("Move cursor", "\u2190 / \u2192 / Home / End"),
            ("Keyboard shortcuts", "Ctrl+x"),
            ("Quit", "Ctrl+q / /exit"),
        ]
        pw = min(self.W - 8, 78)
        ind = " " * max(0, (self.W - pw) // 2)
        title = " Keyboard Shortcuts "
        head = ("\u250c\u2500" + title
                + "\u2500" * max(0, pw - len(title) - 9) + " [\u2717] \u2500\u2510")
        out = [ind + BORDER + head + R]
        out.append(ind + BORDER + "\u2502" + " " * (pw - 2) + "\u2502" + R)
        sep = ind + BORDER + "\u2502" + "\u2500" * (pw - 2) + "\u2502" + R
        out.append(ind + BORDER + "\u2502" + R + "  " + DIM + "\u25c6 "
                   + R + WHITE + "Essentials" + R
                   + " " * max(0, pw - 2 - 2 - 12) + BORDER + "\u2502" + R)
        for label, key in rows:
            left = "    \u25c6 " + label
            fill = pw - 2 - len(left) - len(key) - 3
            out.append(ind + BORDER + "\u2502" + R + DIM + "    \u25c6 " + R
                       + TEXT + label + R + " " * max(1, fill) + KEY + key + R
                       + "   " + BORDER + "\u2502" + R)
        out.append(ind + BORDER + "\u2502" + " " * (pw - 2) + "\u2502" + R)
        foot = "Esc close"
        fpad = (pw - 2 - len(foot)) // 2
        out.append(ind + BORDER + "\u2502" + R + " " * fpad + DIM + foot + R
                   + " " * (pw - 2 - fpad - len(foot)) + BORDER + "\u2502" + R)
        out.append(ind + BORDER + "\u2514" + "\u2500" * (pw - 2) + "\u2518" + R)
        return out

    def draw(self, force=False):
        now = time.time()
        if not force and now - self._last_draw < 0.08:
            return
        self._last_draw = now
        buf = ["\033[?25l"]
        # top bar
        cwd = os.getcwd()
        counter = fmt_tokens(self.used) + " / " + CONTEXT_WINDOW
        room = self.W - len(counter) - 5
        if len(cwd) > room:
            cwd = cwd[: room - 1] + "…"
        pad = self.W - 2 - len(cwd) - len(counter) - 1
        buf.append(self.at(1) + "\033[2K  " + DIM + cwd + R
                   + " " * max(1, pad) + LIGHT + counter + R)
        # transcript (+ optional modal panel)
        content = self.lines + self.cur_lines()
        if self.mode == "menu":
            content = content + [""] + self.menu_panel()
        elif self.mode == "resume":
            content = content + [""] + self.resume_panel()
        elif self.mode == "shortcuts":
            content = content + [""] + self.shortcuts_panel()
        if self.mode == "model":
            content = content + [""] + self.model_panel()
        upper = len(content) - self.scroll
        window = content[max(0, upper - self.RH): upper]
        rows = [""] * (self.RH - len(window)) + window   # ancre en bas
        for i in range(self.RH):
            buf.append(self.at(2 + i) + "\033[2K" + rows[i])
        # popup d'autocompletion des commandes slash (au-dessus de la saisie)
        if self.mode == "input" and self.input_buf.startswith("/"):
            sugg = self.slash_suggestions()
            if sugg:
                n = min(len(sugg), 8)
                base = self.H - 3 - n - 1
                buf.append(self.at(base) + "\033[2K  " + BORDER
                           + "─" * (self.W - 4) + R)
                for j in range(n):
                    name, desc = sugg[j]
                    mark = "❯ " if j == self.slash_i else "  "
                    style = LIGHT if j == self.slash_i else TEXT
                    buf.append(self.at(base + 1 + j) + "\033[2K     " + style
                               + mark + name.ljust(15) + R + DIM
                               + desc[: self.W - 28] + R)
                buf.append(self.at(base + 1 + n) + "\033[2K  " + BORDER
                           + "─" * (self.W - 4) + R)
        # bottom area: input box or status
        tag = " " + self.model_label + " · " + self.pmode + " "
        if self.mode == "busy":
            buf.append(self.at(self.H - 2) + "\033[2K")
            buf.append(self.at(self.H - 1) + "\033[2K" + self.spinner_line())
            buf.append(self.at(self.H) + "\033[2K")
        else:
            shown = self.input_buf[-(self.W - 8):].replace("\n", "⏎")
            pad = max(0, self.W - 5 - dwidth(shown))
            buf.append(self.at(self.H - 2) + "\033[2K" + IBORDER + "╭"
                       + "─" * (self.W - 2) + "╮" + R)
            buf.append(self.at(self.H - 1) + "\033[2K" + IBORDER + "│ " + R
                       + TEXT + "❯ " + LIGHT + shown + R + " " * pad
                       + IBORDER + "│" + R)
            buf.append(self.at(self.H) + "\033[2K" + IBORDER + "╰"
                       + "─" * max(0, self.W - 3 - len(tag)) + R + MODEL
                       + tag + R + IBORDER + "─╯" + R)
        sys.stdout.write("".join(buf))
        if self.mode == "input":
            hidden = len(self.input_buf) - len(shown) if not self.mode == "busy" else 0
            col = 5 + dwidth(shown[: max(0, self.input_pos - hidden)])
            sys.stdout.write(self.at(self.H - 1, min(col, self.W - 2))
                             + "\033[?25h")
        sys.stdout.flush()

    SPIN = "⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"

    def spinner_line(self):
        now = time.time()
        frame = self.SPIN[self.spin_i % len(self.SPIN)]
        left_v = "%s %s… " % (frame, self.phase)
        phase_s = "%.1fs" % (now - (self.phase_t0 or self.turn_t0))
        right_v = "%.1fs ⇣%s  esc to interrupt" % (
            now - self.turn_t0, fmt_tokens(self.recv_chars // 4))
        pad = self.W - 4 - len(left_v) - len(phase_s) - len(right_v) - 2
        return ("   " + TEXT + frame + " " + self.phase + "… " + R + DIM
                + phase_s + " " * max(1, pad) + right_v + R)

    def draw_spinner(self):
        if self.mode != "busy":
            return
        self.spin_i += 1
        sys.stdout.write("\033[?25l" + self.at(self.H - 1) + "\033[2K"
                         + self.spinner_line())
        sys.stdout.flush()

    # ---- grok turn --------------------------------------------------------
    def start_turn(self, prompt):
        self.user_band(prompt)
        self.scroll = 0
        self.mode = "busy"
        self.phase = "Working"
        self.recv_chars = 0
        self.turn_text = ""
        sent = prompt
        if self.carry:
            sent = ("Context carried over from the previous session"
                    " (compacted):\n" + self.carry + "\n\n" + prompt)
            self.carry = None
        cmd = ([GROK_BIN] + EXTRA + PMODE_FLAGS[self.pmode]
               + (["-m", self.model] if self.model else [])
               + ["--output-format", "streaming-json"])
        if self.session_id:
            cmd += ["-r", self.session_id]
            if self.fork_next:
                cmd += ["--fork-session"]
        self.fork_next = False
        cmd += ["-p", sent]
        self.turn_t0 = time.time()
        self.thought_t0 = None
        self.in_thought = False
        self.turn_stop = "?"
        self.proc = subprocess.Popen(cmd, stdout=subprocess.PIPE,
                                     stderr=subprocess.PIPE, text=True,
                                     bufsize=1)

        def reader(p, q):
            for line in p.stdout:
                q.put(("line", line))
            q.put(("eof", p))

        threading.Thread(target=reader, args=(self.proc, self.events),
                         daemon=True).start()

    def handle_event(self, kind, payload):
        if kind == "line":
            raw = payload.strip()
            if not raw:
                return
            try:
                e = json.loads(raw)
            except ValueError:
                self.add_par(DIM, raw)
                return
            t = e.get("type")
            if t == "thought":
                if not self.in_thought:
                    self.thought_t0 = time.time()
                    self.phase = "Thinking"
                    self.phase_t0 = self.thought_t0
                    self.add()
                    self.stream_start(DIM, "◆ Thought  ")
                    self.in_thought = True
                self.recv_chars += len(e.get("data", ""))
                self.stream_add(e.get("data", ""))
            elif t == "text":
                if self.in_thought:
                    self.cur_plain = ""      # the summary replaces the raw stream
                    self.flush_stream()
                    dt = time.time() - (self.thought_t0 or self.turn_t0)
                    self.add_par(DIM, "◆ Thought for %.1fs" % dt)
                    self.add()
                    self.in_thought = False
                if self.cur_style is None:
                    self.stream_start(TEXT, "")
                    self.phase = "Working"
                    self.phase_t0 = time.time()
                self.recv_chars += len(e.get("data", ""))
                self.turn_text += e.get("data", "")
                self.stream_add(e.get("data", ""))
            elif t == "end":
                self.session_id = e.get("sessionId") or self.session_id
                self.used = max(self.used, extract_tokens(e.get("usage")))
                self.turn_stop = e.get("stopReason", "?")
            else:
                self.flush_stream()
                self.in_thought = False
                label = e.get("name") or e.get("tool") or t
                self.add_par(DIM, "[%s]" % label)
        elif kind == "eof":
            p = payload
            err = p.stderr.read()
            rc = p.wait()
            self.flush_stream()
            self.add()
            if rc != 0 and err.strip():
                self.add_par(RED, err.strip()[:300])
            self.add_par(DIM, "Worked for %.1fs.  %s"
                         % (time.time() - self.turn_t0,
                            self.turn_stop.lower()))
            self.proc = None
            self.mode = "input"
            self.scroll = 0
            if self.pending_compact:
                self.pending_compact = False
                self.carry = self.turn_text.strip()[:4000]
                self.session_id = None
                self.add_par(DIM, "[session compacted — the summary will seed"
                             " the next turn]", "  ")

    # ---- resume -----------------------------------------------------------
    def load_sessions(self):
        try:
            out = subprocess.run([GROK_BIN, "sessions", "list", "-n", "12"],
                                 capture_output=True, text=True,
                                 timeout=180).stdout
        except Exception:
            out = ""
        rows = []
        for line in out.splitlines():
            parts = line.split()
            if (len(parts) >= 5 and len(parts[0]) == 36
                    and parts[0].count("-") == 4):
                rows.append((parts[0], parts[1], " ".join(parts[4:])[:70]))
        self.resume_rows = rows
        self.resume_i = 0


def read_keys(fd):
    """Return a list of keys decoded from raw input."""
    data = os.read(fd, 128)
    keys = []
    i = 0
    while i < len(data):
        b = data[i]
        if b == 0x1B:
            m = {b"\x1b[A": "up", b"\x1b[B": "down", b"\x1b[C": "right",
                 b"\x1b[D": "left", b"\x1b[H": "home", b"\x1b[F": "end",
                 b"\x1b[5~": "pgup", b"\x1b[6~": "pgdn",
                 b"\x1b[Z": "shift+tab",
                 b"\x1b[13;2u": "newline", b"\x1b\r": "newline",
                 b"\x1bOA": "up", b"\x1bOB": "down"}
            got = None
            for k, v in sorted(m.items(), key=lambda kv: -len(kv[0])):
                if data[i:i + len(k)] == k:
                    got, ln = v, len(k)
                    break
            if got:
                keys.append(got)
                i += ln
            else:
                keys.append("esc")
                i += 1
        elif b == 0x0D:
            keys.append("enter")
            i += 1
        elif b == 0x0A:
            keys.append("newline")     # Ctrl+J
            i += 1
        elif b == 0x7F:
            keys.append("backspace")
            i += 1
        elif b == 0x03:
            keys.append("ctrl+c")
            i += 1
        elif b == 0x11:
            keys.append("ctrl+q")
            i += 1
        elif b == 0x13:
            keys.append("ctrl+s")
            i += 1
        elif b == 0x18:
            keys.append("ctrl+x")
            i += 1
        elif b == 0x09:
            keys.append("tab")
            i += 1
        elif b == 0x15:
            keys.append("ctrl+u")
            i += 1
        elif b >= 0x20:
            j = i + 1
            while j < len(data) and data[j] >= 0x20 and data[j] != 0x1B:
                j += 1
            keys.append(("txt", data[i:j].decode("utf-8", "ignore")))
            i = j
        else:
            i += 1
    return keys


def run_slash(app, text):
    """Execute une commande slash. Retourne "quit" pour sortir."""
    name = text.split(" ")[0]
    args = text[len(name):].strip()
    if name in ("/quit", "/exit"):
        return "quit"
    if name in ("/new", "/clear"):
        app.session_id = None
        app.add_par(DIM, "[new session]", "  ")
    elif name == "/compact":
        if not app.session_id:
            app.add_par(DIM, "[nothing to compact yet]", "  ")
        else:
            app.pending_compact = True
            app.start_turn("Produce a concise handoff summary of this"
                           " conversation: key facts, decisions and open"
                           " tasks. Plain text, no preamble.")
    elif name == "/fork":
        if app.session_id:
            app.fork_next = True
            app.add_par(DIM, "[next turn will fork this session]", "  ")
        else:
            app.add_par(DIM, "[no session to fork yet]", "  ")
    elif name == "/export":
        if not app.session_id:
            app.add_par(DIM, "[no session to export yet]", "  ")
        else:
            out = os.path.expanduser("~/grok-session-%s.md"
                                     % app.session_id[:8])
            try:
                subprocess.run([GROK_BIN, "export", app.session_id, out],
                               capture_output=True, text=True, timeout=180)
                app.add_par(DIM, "[exported: %s]" % out, "  ")
            except Exception as exc:
                app.add_par(RED, "export failed: %s" % exc, "  ")
    elif name == "/mcps":
        try:
            out = subprocess.run([GROK_BIN, "mcp", "list"],
                                 capture_output=True, text=True,
                                 timeout=180).stdout.strip()
        except Exception as exc:
            out = "mcp list failed: %s" % exc
        for line in (out or "(no MCP servers configured)").splitlines():
            app.add_par(DIM, line, "  ")
    elif name == "/remember":
        if args:
            app.start_turn("Remember this for future sessions: " + args)
        else:
            app.add_par(DIM, "[usage: /remember <note>]", "  ")
    elif name == "/multiline":
        app.multiline = not app.multiline
        app.add_par(DIM, "[multiline %s — Enter inserts a newline, Ctrl+J"
                    " sends]" % ("ON" if app.multiline else "OFF")
                    if app.multiline else "[multiline OFF — Enter sends]",
                    "  ")
    elif name == "/docs":
        app.add_par(DIM, "docs: https://github.com/xai-org/grok-build"
                    " (user guide in crates/codegen/xai-grok-pager/docs)", "  ")
    elif name == "/version":
        try:
            v = subprocess.run([GROK_BIN, "--version"], capture_output=True,
                               text=True, timeout=120).stdout.strip()
        except Exception:
            v = "unknown"
        app.add_par(DIM, v, "  ")
    elif name in ("/resume", "/sessions"):
        app.load_sessions()
        if app.resume_rows:
            app.mode = "resume"
    elif name == "/model":
        app.add_par(DIM, "[loading models…]", "  ")
        app.draw(force=True)
        app.load_models()
        app.lines.pop()
        if app.model_rows:
            app.mode = "model"
        else:
            app.add_par(DIM, "[no models found]", "  ")
    elif name == "/help":
        app.mode = "shortcuts"
    elif name == "/home":
        app.welcome()
        app.mode = "menu"
    elif name == "/session-info":
        app.add_par(DIM, "session: %s" % (app.session_id or "(new)"), "  ")
        app.add_par(DIM, "model: %s · mode: %s · context: %s"
                    % (app.model or app.model_label, app.pmode,
                       fmt_tokens(app.used)), "  ")
    elif name == "/recap":
        app.start_turn("Summarize the session so far in a few short bullet points.")
    else:
        app.add_par(DIM, "[unknown command: %s]" % name, "  ")
    return None


def main_tui():
    app = App()
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    new = termios.tcgetattr(fd)
    new[3] = new[3] & ~(termios.ICANON | termios.ECHO)   # cbreak
    # IXON: free ctrl+s/q from flow control. ICRNL/INLCR/IGNCR: keep Enter
    # as CR (0x0D) so it stays distinct from Ctrl+J (0x0A = newline).
    new[0] = new[0] & ~(termios.IXON | termios.ICRNL
                        | termios.INLCR | termios.IGNCR)
    termios.tcsetattr(fd, termios.TCSANOW, new)
    # ?7l : autowrap OFF — ecrire la derniere cellule (coin bas-droit) ferait
    # defiler tout l'ecran d'une ligne sur la plupart des terminaux, poussant
    # la boite de saisie hors de la vue.
    sys.stdout.write("\033[?1049h\033[?7l\033[2J")
    sys.stdout.write("\033[2;%dr" % (app.H - 4))
    app.welcome()
    app.draw(force=True)
    try:
        while True:
            rl, _, _ = select.select([fd], [], [], 0.05)
            drained = False
            try:
                while True:
                    kind, payload = app.events.get_nowait()
                    app.handle_event(kind, payload)
                    drained = True
            except queue.Empty:
                pass
            if drained:
                app.draw(force=(app.mode == "input"))
            if not rl:
                app.check_resize()
                if app.mode == "busy":
                    app.draw_spinner()
                continue
            for key in read_keys(fd):
                m = app.mode
                if key == "ctrl+q":
                    return
                if key in ("pgup", "pgdn"):
                    content_len = len(app.lines) + len(app.cur_lines())
                    step = app.RH - 2
                    if key == "pgup":
                        app.scroll = min(max(0, content_len - app.RH),
                                         app.scroll + step)
                    else:
                        app.scroll = max(0, app.scroll - step)
                    app.draw(force=True)
                    continue
                if m == "shortcuts":
                    if key in ("esc", "ctrl+x", "enter"):
                        app.mode = "input"
                        app.draw(force=True)
                    elif isinstance(key, tuple):
                        app.mode = "input"
                        app.input_buf = key[1]
                        app.input_pos = len(app.input_buf)
                        app.draw(force=True)
                    continue
                if key == "ctrl+x" and m in ("menu", "input"):
                    app.mode = "shortcuts"
                    app.draw(force=True)
                    continue
                if key == "shift+tab" and m in ("menu", "input"):
                    i = (PMODES.index(app.pmode) + 1) % len(PMODES)
                    app.pmode = PMODES[i]
                    if app.mode == "menu":
                        app.mode = "input"
                    app.draw(force=True)
                    continue
                if m == "menu":
                    if key == "up":
                        app.menu_i = (app.menu_i - 1) % 3
                    elif key == "down":
                        app.menu_i = (app.menu_i + 1) % 3
                    elif key == "enter":
                        if app.menu_i == 0:
                            app.mode = "input"
                        elif app.menu_i == 1:
                            app.load_sessions()
                            app.mode = ("resume" if app.resume_rows
                                        else "input")
                        else:
                            return
                    elif key == "esc":
                        app.mode = "input"
                    elif isinstance(key, tuple):
                        app.mode = "input"
                        app.input_buf = key[1]
                        app.input_pos = len(app.input_buf)
                    app.draw(force=True)
                elif m == "model":
                    n = max(1, len(app.model_rows))
                    if key == "up":
                        app.model_i = (app.model_i - 1) % n
                    elif key == "down":
                        app.model_i = (app.model_i + 1) % n
                    elif key == "enter" and app.model_rows:
                        name, _ = app.model_rows[app.model_i]
                        app.model = name
                        app.model_label = name
                        app.add_par(DIM, "[model: %s]" % name, "  ")
                        app.mode = "input"
                    elif key == "esc":
                        app.mode = "input"
                    app.draw(force=True)
                elif m == "resume":
                    n = max(1, len(app.resume_rows))
                    if key == "up":
                        app.resume_i = (app.resume_i - 1) % n
                    elif key == "down":
                        app.resume_i = (app.resume_i + 1) % n
                    elif key == "enter" and app.resume_rows:
                        sid, _, summary = app.resume_rows[app.resume_i]
                        app.session_id = sid
                        app.add_par(DIM, "[resumed: %s]" % summary, "  ")
                        app.mode = "input"
                    elif key == "esc":
                        app.mode = "input"
                    app.draw(force=True)
                elif m == "busy":
                    if key in ("esc", "ctrl+c") and app.proc:
                        app.proc.terminate()
                        app.phase = "Interrupting"
                        app.draw(force=True)
                elif m == "input":
                    if app.multiline and key in ("enter", "newline"):
                        key = "newline" if key == "enter" else "enter"
                    if key == "enter":
                        text = app.input_buf.strip()
                        if text.startswith("/"):
                            sugg = app.slash_suggestions()
                            names = [c[0] for c in sugg]
                            if text.split(" ")[0] not in names and sugg:
                                text = sugg[app.slash_i][0]
                        app.input_buf = ""
                        app.input_pos = 0
                        app.slash_i = 0
                        if not text:
                            app.draw(force=True)
                            continue
                        if text == "exit" or (text.startswith("/")
                                              and run_slash(app, text) == "quit"):
                            return
                        if not text.startswith("/"):
                            app.hist.append(text)
                            app.hist_i = len(app.hist)
                            app.start_turn(text)
                        app.draw(force=True)
                    elif key == "tab" and app.input_buf.startswith("/"):
                        sugg = app.slash_suggestions()
                        if sugg:
                            app.input_buf = sugg[app.slash_i][0]
                            app.input_pos = len(app.input_buf)
                        app.draw(force=True)
                    elif (key in ("up", "down")
                          and app.input_buf.startswith("/")
                          and app.slash_suggestions()):
                        n = len(app.slash_suggestions())
                        app.slash_i = (app.slash_i + (1 if key == "down" else -1)) % n
                        app.draw(force=True)
                    elif key == "backspace":
                        if app.input_pos > 0:
                            app.input_buf = (
                                app.input_buf[:app.input_pos - 1]
                                + app.input_buf[app.input_pos:])
                            app.input_pos -= 1
                        app.draw(force=True)
                    elif key == "left":
                        app.input_pos = max(0, app.input_pos - 1)
                        app.draw(force=True)
                    elif key == "right":
                        app.input_pos = min(len(app.input_buf),
                                            app.input_pos + 1)
                        app.draw(force=True)
                    elif key in ("home", "end"):
                        app.input_pos = (0 if key == "home"
                                         else len(app.input_buf))
                        app.draw(force=True)
                    elif key == "up":
                        if app.hist:
                            app.hist_i = max(0, app.hist_i - 1)
                            app.input_buf = app.hist[app.hist_i]
                            app.input_pos = len(app.input_buf)
                            app.draw(force=True)
                    elif key == "down":
                        if app.hist:
                            app.hist_i = min(len(app.hist), app.hist_i + 1)
                            app.input_buf = (app.hist[app.hist_i]
                                             if app.hist_i < len(app.hist)
                                             else "")
                            app.input_pos = len(app.input_buf)
                            app.draw(force=True)
                    elif key == "newline":
                        app.input_buf = (app.input_buf[:app.input_pos] + "\n"
                                         + app.input_buf[app.input_pos:])
                        app.input_pos += 1
                        app.draw(force=True)
                    elif key in ("esc", "ctrl+u"):
                        app.input_buf = ""
                        app.input_pos = 0
                        app.slash_i = 0
                        app.draw(force=True)
                    elif key == "ctrl+s":
                        app.load_sessions()
                        if app.resume_rows:
                            app.mode = "resume"
                            app.draw(force=True)
                    elif key == "ctrl+c":
                        return
                    elif isinstance(key, tuple):
                        app.input_buf = (app.input_buf[:app.input_pos]
                                         + key[1]
                                         + app.input_buf[app.input_pos:])
                        app.input_pos += len(key[1])
                        app.draw(force=True)
    finally:
        termios.tcsetattr(fd, termios.TCSANOW, old)
        sys.stdout.write("\033[?25h\033[?7h\033[?1049l")
        sys.stdout.flush()


def main_simple():
    """No-TTY fallback (pipe): basic sequential mode."""
    session = None
    for raw in sys.stdin:
        prompt = raw.strip()
        if not prompt:
            continue
        if prompt in ("/exit", "/quit", "exit"):
            break
        cmd = [GROK_BIN] + EXTRA + ["--output-format", "streaming-json"]
        if session:
            cmd += ["-r", session]
        cmd += ["-p", prompt]
        print("❯ " + prompt)
        p = subprocess.Popen(cmd, stdout=subprocess.PIPE,
                             stderr=subprocess.DEVNULL, text=True, bufsize=1)
        for line in p.stdout:
            line = line.strip()
            if not line:
                continue
            try:
                e = json.loads(line)
            except ValueError:
                continue
            if e.get("type") == "text":
                sys.stdout.write(e.get("data", ""))
                sys.stdout.flush()
            elif e.get("type") == "end":
                session = e.get("sessionId") or session
        p.wait()
        print()


if __name__ == "__main__":
    if sys.stdin.isatty() and sys.stdout.isatty():
        main_tui()
    else:
        main_simple()
